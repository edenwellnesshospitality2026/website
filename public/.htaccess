# React Router (BrowserRouter): serve index.html for non-file routes.
# Copied to dist/ on build. If the site lives in a subfolder, set RewriteBase (e.g. /myapp/).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
